---
interface Props {
  slug: string;
  title: string;
  lokasyon: string;
  calismaSekli?: string;
  ozet?: string;
}
const { slug, title, lokasyon, calismaSekli, ozet } = Astro.props;
const calismaSekliEtiketleri: Record<string, string> = {
  'tam-zamanli': 'Tam zamanlı',
  'yari-zamanli': 'Yarı zamanlı',
  'staj': 'Staj',
  'proje-bazli': 'Proje bazlı',
};
---
<a href={`/kariyer/${slug}`} class="block border border-slate-200 rounded-lg p-5 hover:border-accent transition-colors">
  <h3 class="text-lg font-semibold text-ink mb-1">{title}</h3>
  <p class="text-sm text-slate-500 mb-2">
    {lokasyon}{calismaSekli && ` · ${calismaSekliEtiketleri[calismaSekli] ?? calismaSekli}`}
  </p>
  {ozet && <p class="text-sm text-slate-600">{ozet}</p>}
</a>
