---
const links = [
  { href: '/', label: 'Ana Sayfa' },
  { href: '/hizmetlerimiz', label: 'Hizmetlerimiz' },
  { href: '/makaleler', label: 'Makaleler' },
  { href: '/ev-verileri', label: 'EV Verileri' },
  { href: '/kariyer', label: 'Kariyer' },
  { href: '/referanslar', label: 'Referanslar' },
];
const current = Astro.url.pathname;
---
<header class="border-b border-slate-200 bg-white/90 backdrop-blur sticky top-0 z-10">
  <nav class="mx-auto max-w-5xl px-4 py-3 flex flex-wrap items-center gap-x-6 gap-y-2">
    <a href="/" class="mr-auto flex items-center">
      <img src="/images/logo-wordmark.png" alt="Arsan Danışmanlık" class="h-6 w-auto" />
    </a>
    {links.slice(1).map((link) => {
      const active = current === link.href || (link.href !== '/' && current.startsWith(link.href));
      return (
        <a
          href={link.href}
          class={`text-sm transition-colors ${active ? 'text-accent font-medium' : 'text-slate-600 hover:text-accent'}`}
        >
          {link.label}
        </a>
      );
    })}
  </nav>
</header>
