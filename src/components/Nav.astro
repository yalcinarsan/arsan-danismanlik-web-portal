---
const links = [
  { href: '/', label: 'Ana Sayfa' },
  { href: '/hizmetlerimiz', label: 'Hizmetlerimiz' },
  { href: '/makaleler', label: 'Makaleler' },
  { href: '/ev-verileri', label: 'EA Verileri' },
  { href: '/kariyer', label: 'Kariyer' },
  { href: '/referanslar', label: 'Referanslarımız' },
];
const current = Astro.url.pathname;
---
<header class="border-b border-warm-border bg-paper/90 backdrop-blur sticky top-0 z-10">
  <nav class="relative mx-auto max-w-5xl px-4 py-3 flex items-center justify-between">
    <a href="/" class="flex items-center self-center">
      <img src="/images/logo-wordmark.png" alt="Arsan Danışmanlık" class="h-9 w-auto block" />
    </a>

    <button
      id="nav-toggle"
      type="button"
      aria-label="Menüyü aç/kapat"
      aria-expanded="false"
      aria-controls="nav-links"
      class="md:hidden flex items-center justify-center w-9 h-9 text-warm-600 hover:text-accent"
    >
      <svg id="nav-icon-open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
      </svg>
      <svg id="nav-icon-close" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <div
      id="nav-links"
      class="hidden md:flex md:static md:flex md:flex-row md:items-center md:gap-x-6 md:border-0 md:bg-transparent md:p-0 md:shadow-none
        absolute inset-x-0 top-full flex-col gap-y-1 border-b border-warm-border bg-paper px-4 py-3 shadow-sm"
    >
      {links.slice(1).map((link) => {
        const active = current === link.href || (link.href !== '/' && current.startsWith(link.href));
        return (
          <a
            href={link.href}
            class={`text-sm transition-colors ${active ? 'text-accent font-medium' : 'text-warm-600 hover:text-accent'}`}
          >
            {link.label}
          </a>
        );
      })}
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const links = document.getElementById('nav-links');
  const iconOpen = document.getElementById('nav-icon-open');
  const iconClose = document.getElementById('nav-icon-close');

  toggle?.addEventListener('click', () => {
    const acilacak = links?.classList.contains('hidden');
    links?.classList.toggle('hidden');
    links?.classList.toggle('flex');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!!acilacak));
  });
</script>
