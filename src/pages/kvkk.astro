---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Content, frontmatter } from '../icerik/kvkk.md';

const { baslik, aciklama, taslak, guncelleme } = frontmatter;
const guncellemeStr = new Intl.DateTimeFormat('tr-TR', { dateStyle: 'long' }).format(new Date(guncelleme));
---
<BaseLayout title={baslik} description={aciklama}>
  {/* Taslak sürüm arama motorlarına kapalı — hukukçu onayı gelince frontmatter'da taslak: false yapılır. */}
  {taslak && <meta name="robots" content="noindex, nofollow" slot="head" />}

  <section class="mx-auto max-w-2xl px-4 py-16">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent mb-3">Otomotiv İnsanı</p>
    <h1 class="text-3xl font-semibold text-ink mb-3">{baslik}</h1>
    <p class="text-sm text-warm-500 mb-10">Son güncelleme: {guncellemeStr}</p>

    {taslak && (
      <div class="rounded-md border border-amber-400/60 bg-amber-50 p-4 mb-10 text-sm text-amber-900">
        <strong class="font-semibold">Taslak metin — hukukçu onayı bekleniyor.</strong>
        Bu sayfa henüz yayına hazır değildir; nihai metin onaylandığında güncellenecektir.
      </div>
    )}

    <div class="prose prose-stone max-w-none prose-headings:font-semibold prose-a:text-accent">
      <Content />
    </div>
  </section>
</BaseLayout>
