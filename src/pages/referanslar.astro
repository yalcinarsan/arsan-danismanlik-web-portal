---
import BaseLayout from '../layouts/BaseLayout.astro';

const referanslar = [
  'Agco',
  'Anadolu Motor',
  'Atlas Copco',
  'Audi Türkiye',
  'Borusan Oto',
  'Borusan Otomotiv',
  'Castrol',
  'Çullas A.Ş.',
  'Doğan Trend Otomotiv Grubu',
  'Doğuş Otomotiv',
  'E-Garaj',
  'Enerjisa',
  'Ford Otosan',
  'Husqvarna',
  'JLR (Jaguar Land Rover) grubu',
  'Kubota',
  'Mahindra (Hindistan)',
  'OSD (Otomotiv Sanayii Derneği)',
  'OSS (Otomotiv Satış Sonrası Derneği)',
  'Otokoç',
  'Pluginn',
  'Same Deutz Fahr',
  'Skoda Avrupa',
  'Stellantis Türkiye',
  'Taysad (Taşıt Araçları Yan Sanayi Derneği)',
  'TÜAD (Türkiye Araştırmacılar Derneği)',
  'Volvo Türkiye',
];
---
<BaseLayout title="Referanslar" description="Bugüne kadar ortak çalışma yaptığımız marka ve kurumlar.">
  <section class="mx-auto max-w-3xl px-4 py-16">
    <h1 class="text-3xl font-semibold text-ink mb-2">Referanslarımız</h1>
    <p class="text-lg text-warm-500 mb-10">
      Bugüne kadar ortak çalışma yaptığımız marka ve kurumlar (alfabetik sıra ile).
    </p>

    <ul class="grid gap-x-6 gap-y-3 sm:grid-cols-2 border-t border-warm-border pt-8">
      {referanslar.map((ad) => (
        <li class="text-warm-700 border-b border-warm-border pb-2">{ad}</li>
      ))}
    </ul>

    <p class="text-warm-600 mt-10 text-sm">
      Ayrıca uluslararası projelerde Almanya merkezli Emobility Experts ile iş birliği yapıyoruz.
    </p>
  </section>
</BaseLayout>
