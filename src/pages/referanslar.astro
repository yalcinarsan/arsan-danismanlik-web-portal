---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Referanslar" description="Arsan Danışmanlık'ın çalışma ortaklıkları ve referansları.">
  <section class="mx-auto max-w-2xl px-4 py-16">
    <h1 class="text-3xl font-semibold text-ink mb-8">Referanslarımız</h1>
    <p class="text-lg leading-relaxed text-slate-700 mb-4">
      Uluslararası projelerde Almanya merkezli Emobility Experts ile iş birliği yapıyor, bu yolla yurt dışı
      perspektifini projelerimizin bir parçası olarak kullanıyoruz.
    </p>
    <p class="text-slate-500 border border-dashed border-slate-300 rounded-lg p-6 text-center mt-8">
      Müşteri referanslarımız yakında burada.
    </p>
  </section>
</BaseLayout>
