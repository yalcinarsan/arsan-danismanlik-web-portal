---
import BaseLayout from '../../layouts/BaseLayout.astro';
import KayitFormu from '../../components/KayitFormu.tsx';
---
<BaseLayout
  title="Otomotiv İnsanı — Kayıt"
  description="Otomotive özgü yetenek havuzuna katıl."
>
  <section class="mx-auto max-w-2xl px-4 py-16">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent mb-3">Otomotiv İnsanı</p>
    <h1 class="text-3xl font-semibold text-ink mb-3">Otomotiv Yetenek Havuzu</h1>
    <p class="text-warm-600 mb-10">
      Profilin, otomotive özgü niteliklerle tanımlanır ve senin belirlediğin görünürlük
      seviyesinde paylaşılır. Kaydolmak sadece birkaç dakika.
    </p>
    <KayitFormu client:load />
    <p class="mt-10 text-sm text-warm-500">
      Zaten kayıtlıysan <a href="/kariyer/profilim" class="text-accent hover:underline">profilini buradan görüntüleyebilirsin</a>.
    </p>
  </section>
</BaseLayout>
