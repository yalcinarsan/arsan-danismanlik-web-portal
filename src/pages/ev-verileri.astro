---
import BaseLayout from '../layouts/BaseLayout.astro';
import EvChart from '../components/charts/EvChart.tsx';
import {
  worldPowertrainConfig,
  regionSalesConfig,
  regionShareConfig,
  turkiyeSatisConfig,
  turkiyeStokConfig,
} from '../components/charts/chartConfigs';
import evData from '../data/ev-data.json';
import { frontmatter as t } from '../icerik/ev-verileri.md';

const { meta } = evData;
const fetchedAt = new Intl.DateTimeFormat('tr-TR', { dateStyle: 'long' }).format(new Date(meta.fetchedAt));

const charts = [
  { config: worldPowertrainConfig, note: t.not_1_dunya_guc_aktarma_grafigi },
  { config: regionSalesConfig, note: t.not_2_dunya_avrupa_satis_grafigi },
  { config: regionShareConfig, note: t.not_3_pazar_payi_grafigi },
  { config: turkiyeSatisConfig, note: t.not_4_turkiye_satis_pazar_payi_grafigi },
  { config: turkiyeStokConfig, note: t.not_5_turkiye_arac_parki_grafigi },
];
---
<BaseLayout title={t.baslik_tag} description={t.aciklama}>
  <section class="mx-auto max-w-4xl px-4 pt-16 pb-8">
    <h1 class="text-3xl font-semibold text-ink mb-4">{t.h1}</h1>
    <p class="text-warm-600 leading-relaxed mb-4">{t.giris}</p>
    <p class="text-sm text-warm-500">Veri çekilme tarihi: {fetchedAt}</p>
  </section>

  <div class="bg-sand">
    <section class="mx-auto max-w-4xl px-4 py-8">
      <h2 class="text-base font-semibold text-ink mb-2">{t.kesikli_baslik}</h2>
      <p class="text-sm text-warm-600 leading-relaxed">{t.kesikli_metin}</p>
    </section>
  </div>

  <section class="mx-auto max-w-4xl px-4 py-16 space-y-20">
    {charts.map(({ config, note }) => (
      <figure class="m-0">
        <h2 class="text-lg font-semibold text-ink mb-4">{config.title}</h2>
        <EvChart client:only="react" config={config} />
        <figcaption class="text-sm text-warm-500 leading-relaxed mt-4">{note}</figcaption>
      </figure>
    ))}
  </section>

  <div class="bg-sand">
    <section class="mx-auto max-w-4xl px-4 py-12">
      <h2 class="text-base font-semibold text-ink mb-3">{t.kaynak_baslik}</h2>
      <p class="text-sm text-warm-600 leading-relaxed mb-3">
        {meta.source} —
        <a href={meta.sourceUrl} class="text-accent hover:underline" rel="noopener" target="_blank">
          Global EV Data Explorer
        </a>. Lisans:
        <a href={meta.licenceUrl} class="text-accent hover:underline" rel="license noopener" target="_blank">
          {meta.licence}
        </a>. Veri, {meta.modifiedBy} tarafından bu grafikler için seçilmiş ve işlenmiştir.
      </p>
      <p class="text-sm text-warm-600 leading-relaxed mb-3">{meta.excluded}</p>
      <p class="text-sm text-warm-500 leading-relaxed">{t.kaynak_ek_metin}</p>
    </section>
  </div>
</BaseLayout>
