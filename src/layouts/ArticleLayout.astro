---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { getCollection } from 'astro:content';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  ozet?: string;
  tarih: Date;
  seri: string;
  seriNo: number;
  seriBaslik?: string;
  url?: string;
  headings?: Heading[];
}

const { title, ozet, tarih, seri, seriNo, seriBaslik, url, headings = [] } = Astro.props;

const seriEtiketleri: Record<string, string> = {
  'otomotivde-elektrifikasyon': 'Otomotivde Elektrifikasyon',
  'beyond-the-balance-sheet': 'Bilançonun Ötesinde: Bir Şirketi Anlamak',
};

const seriMakaleleri = (await getCollection('articles'))
  .filter((a) => a.data.seri === seri && a.data.durum === 'yayında')
  .sort((a, b) => a.data.seriNo - b.data.seriNo);

const currentIndex = seriMakaleleri.findIndex((a) => a.data.seriNo === seriNo);
const prev = currentIndex > 0 ? seriMakaleleri[currentIndex - 1] : null;
const next = currentIndex >= 0 && currentIndex < seriMakaleleri.length - 1 ? seriMakaleleri[currentIndex + 1] : null;

const tarihStr = new Intl.DateTimeFormat('tr-TR', { year: 'numeric', month: 'long' }).format(tarih);

const site = Astro.site ?? new URL('https://arsandanismanlik.com.tr');
const pageUrl = new URL(Astro.url.pathname, site).href;

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: ozet,
  inLanguage: 'tr',
  datePublished: tarih.toISOString(),
  dateModified: tarih.toISOString(),
  author: { '@type': 'Person', '@id': `${site.origin}/#person`, name: 'Yalçın Arsan' },
  publisher: { '@id': `${site.origin}/#organization` },
  mainEntityOfPage: pageUrl,
  articleSection: seriEtiketleri[seri] ?? seri,
  license: 'https://creativecommons.org/licenses/by/4.0/',
  isAccessibleForFree: true,
};
---
<BaseLayout title={title} description={ozet} ogType="article">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleLd)} />
  <meta property="article:published_time" content={tarih.toISOString()} slot="head" />
  <meta property="article:author" content="Yalçın Arsan" slot="head" />
  {url && <meta property="article:opensource_url" content={url} slot="head" />}

  <div class="mx-auto max-w-4xl px-4 py-12 flex gap-12 justify-center">
    <article class="max-w-2xl min-w-0 flex-1">
      <p class="text-sm text-accent font-medium mb-2">
        {seriEtiketleri[seri] ?? seri} · {seriBaslik ?? `Bölüm ${seriNo}`}
      </p>
      <h1 class="text-3xl font-semibold text-ink mb-2">{title}</h1>
      <p class="text-sm text-warm-500 mb-10">{tarihStr}</p>
      <div class="prose prose-stone max-w-none prose-headings:font-semibold prose-headings:scroll-mt-20 prose-a:text-accent prose-figcaption:text-center prose-figcaption:text-warm-500 prose-img:cursor-zoom-in">
        <slot />
      </div>
      <footer class="mt-16 pt-8 border-t border-warm-border">
        <h2 class="text-xs font-semibold uppercase tracking-wide text-warm-500 mb-4">Serinin diğer yazıları</h2>
        <ol class="space-y-2 mb-8">
          {seriMakaleleri.map((a) => (
            a.data.seriNo === seriNo ? (
              <li class="text-sm text-ink font-medium">
                {a.data.seriNo}. {a.data.title}
                <span class="text-warm-400 font-normal"> — şu an buradasınız</span>
              </li>
            ) : (
              <li class="text-sm">
                <a href={`/makaleler/${a.slug}`} class="text-accent hover:underline">{a.data.seriNo}. {a.data.title}</a>
              </li>
            )
          ))}
        </ol>
        <nav class="flex justify-between text-sm gap-4">
          {prev ? (
            <a href={`/makaleler/${prev.slug}`} class="text-accent hover:underline">← {prev.data.seriBaslik ?? prev.data.title}</a>
          ) : <span />}
          {next ? (
            <a href={`/makaleler/${next.slug}`} class="text-accent hover:underline">{next.data.seriBaslik ?? next.data.title} →</a>
          ) : <span />}
        </nav>
        <p class="mt-8 text-xs leading-relaxed text-warm-400">
          Bu yazı Yalçın Arsan tarafından yazılmıştır. Kaynak göstererek —
          <span class="text-warm-500">Yalçın Arsan · Arsan Danışmanlık</span>, bu sayfaya bağlantı —
          özgürce alıntılayabilir, paylaşabilir ve üzerine kurabilirsiniz.
          <a href="https://creativecommons.org/licenses/by/4.0/" rel="license" class="underline hover:text-accent">CC BY 4.0</a>
        </p>
      </footer>
    </article>
    <TableOfContents headings={headings} />
  </div>

  <div id="lightbox" aria-hidden="true">
    <img id="lightbox-img" src="" alt="" />
  </div>
  <style>
    #lightbox {
      position: fixed;
      inset: 0;
      z-index: 50;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      background: rgba(20, 16, 12, 0.9);
      cursor: zoom-out;
    }
    #lightbox.open { display: flex; }
    #lightbox img {
      max-width: 95vw;
      max-height: 92vh;
      width: auto;
      height: auto;
      background: #fff;
      padding: 1rem;
      box-sizing: border-box;
      border-radius: 6px;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
    }
  </style>
  <script>
    const box = document.getElementById('lightbox');
    const boxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
    if (box && boxImg) {
      document.querySelectorAll<HTMLImageElement>('.prose img').forEach((img) => {
        img.addEventListener('click', () => {
          boxImg.src = img.currentSrc || img.src;
          boxImg.alt = img.alt;
          box.classList.add('open');
          box.setAttribute('aria-hidden', 'false');
        });
      });
      const close = () => {
        box.classList.remove('open');
        box.setAttribute('aria-hidden', 'true');
      };
      box.addEventListener('click', close);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') close();
      });
    }
  </script>
</BaseLayout>
